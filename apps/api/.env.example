# Local:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hub_central?schema=public"
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
PORT=3001
JWT_SECRET=hub-central-secret-key-change-in-production
JWT_EXPIRES=7d
ADMIN_ORIGIN=https://seu-admin.vercel.app

# Google OAuth (mesmo Client ID do frontend)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# Resend (recomendado) — https://resend.com/api-keys
RESEND_API_KEY=re_sua_api_key_aqui
# Sem domínio verificado: onboarding@resend.dev (só envia p/ e-mail da conta Resend)
MAIL_FROM=Hub Central <onboarding@resend.dev>

# Alternativa: SMTP Resend (RESEND_API_KEY tem prioridade se começar com re_)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_sua_api_key_aqui
